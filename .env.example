# Database — local PostgreSQL for dev, Neon for production
DATABASE_URL="postgresql://<user>@localhost:5432/hxaihub?schema=public"

# Google OAuth — create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Set to "true" to allow any Google account (dev only)
# Remove or set to "false" in production to restrict to @holidayextras.com
ALLOW_ALL_DOMAINS="true"
